<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff Dashboard - HAVEN</title>
    <link rel="stylesheet" href="/css/staff.css">
</head>
<body>
    <div class="header-gradient">
        <div class="header-title">Staff Dashboard</div>
        <button class="logout-btn" onclick="window.location.href='/'">Logout</button>
    </div>

    <div class="sidebar">
        <div class="sidebar-logo">
            <span>HAVEN</span>
        </div>
        <div class="sidebar-menu">
            <a href="/profile" class="sidebar-item"><span>User Profile</span></a>
            <a href="/staff" class="sidebar-item active"><span>Staff Dashboard</span></a>
            <a href="/schedule" class="sidebar-item"><span>Schedule</span></a>
            <a href="/messages" class="sidebar-item"><span>Messages</span></a>
            <a href="#" class="sidebar-item"><span>Settings</span></a>
        </div>
    </div>

    <div class="main-content">
        
        <div class="dashboard-row">
            <div class="dashboard-card today-highlight">
                <div class="card-title">Today's Schedule</div>
                <div id="todayScheduleContent" class="shift-list"></div>
            </div>
            
            <div class="dashboard-card action-card">
                <div class="card-title">Need Help?</div>
                <p>Encountered a problem during your shift?</p>
                <button class="report-btn">Report Issue</button>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="section-container">
                <h2>Weekly Shifts</h2>
                <div class="content-box" id="weeklyShiftList"></div>
            </div>

            <div class="section-container">
                <h2>To-Do List</h2>
                <div class="content-box todo-container">
                    <form id="todoForm" class="todo-form">
                        <input id="todoInput" type="text" placeholder="Add a new task..." autocomplete="off" required>
                        <button type="submit" class="add-btn">Add</button>
                    </form>
                    <div id="todoList" class="todo-list"></div>
                </div>
            </div>
        </div>

    <script>window.currentStaffUsername = "<%= user ? user.username : 'guest' %>";</script>
    <script src="/js/staff_dashboard.js"></script>
    </div>
</body>
</html>