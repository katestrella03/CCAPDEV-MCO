<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staffing Portal - HAVEN</title>

    <!--  FIX CSS -->
    <link rel="stylesheet" href="/css/staffing.css">
</head>
<body>

    <!-- HEADER -->
    <div class="header-gradient">
        <div class="header-title">Staffing Portal</div>

        <!--  FIX LOGOUT -->
        <button class="logout-btn" onclick="window.location.href='/'">Logout</button>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-logo">
            <span style="font-weight: bold; font-size: 1.2rem;">HAVEN</span>
        </div>

        <div class="sidebar-menu">
            <!--  FIX ALL LINKS -->
            <a href="/manager" class="sidebar-item">Dashboard</a>
            <a href="/profile" class="sidebar-item">User Profile</a>
            <a href="/staffing" class="sidebar-item active">Staffing</a>
            <a href="/messages" class="sidebar-item">Messages</a>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main-content">

        <div class="action-buttons">
            <button class="assign-btn" onclick="assignStaffToEvent()">Assign Selected</button>
            <button class="clear-btn" onclick="clearSelections()">Clear Selections</button>
        </div>

        <div class="assignment-wrapper">

            <div class="section events-section">
                <h2>Events</h2>
                <div class="events-list" id="eventsList"></div>
            </div>

            <div class="section staff-section">
                <h2>Available Staff</h2>
                <select id="staffRoleFilter" class="role-filter" onchange="applyRoleFilter()">
                    <option value="">All Roles</option>
                </select>
                <div class="staff-list" id="staffList"></div>
            </div>

            <div class="section assignments-section">
                <h2>Event Assignments</h2>
                <div class="assignments-container" id="assignmentsContainer"></div>
            </div>

        </div>
    </div>

    <!--  FIX JS -->
    <script src="/js/staffing.js"></script>

</body>
</html>